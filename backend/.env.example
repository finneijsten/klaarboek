# Environment: set to "production" on deploy to enforce secret-key checks.
ENVIRONMENT=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Auth — MUST be a random string of >=32 chars in production.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=generate-a-secure-random-string-here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS: comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000

# Nordigen / GoCardless (PSD2 bank sync, feature-flagged).
# Leave empty to disable the /banks/institutions + /connect + /callback + /sync
# endpoints (they will return 503).
NORDIGEN_SECRET_ID=
NORDIGEN_SECRET_KEY=
